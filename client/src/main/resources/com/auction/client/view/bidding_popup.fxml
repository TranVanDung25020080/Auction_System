<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox prefWidth="650.0" spacing="15.0" style="-fx-background-color: #f4f4f4; -fx-padding: 20;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.BiddingPopupController">
    <children>
        <Label text="CHI TIẾT PHIÊN ĐẤU GIÁ" maxWidth="Infinity" alignment="CENTER">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>

        <GridPane hgap="1.0" vgap="1.0" style="-fx-background-color: #ccc; -fx-border-color: #ccc;">
            <columnConstraints>
                <ColumnConstraints prefWidth="50" halignment="CENTER" />
                <ColumnConstraints prefWidth="150" halignment="CENTER" />
                <ColumnConstraints prefWidth="120" halignment="CENTER" />
                <ColumnConstraints prefWidth="150" halignment="CENTER" />
                <ColumnConstraints prefWidth="130" halignment="CENTER" />
            </columnConstraints>
            <children>
                <Label text="Mã ID" style="-fx-background-color: #eee; -fx-padding: 8; -fx-font-weight: bold;" maxWidth="Infinity" GridPane.columnIndex="0" />
                <Label text="Tên sản phẩm" style="-fx-background-color: #eee; -fx-padding: 8; -fx-font-weight: bold;" maxWidth="Infinity" GridPane.columnIndex="1" />
                <Label text="Giá khởi điểm" style="-fx-background-color: #eee; -fx-padding: 8; -fx-font-weight: bold;" maxWidth="Infinity" GridPane.columnIndex="2" />
                <Label text="Giá hiện tại" style="-fx-background-color: #eee; -fx-padding: 8; -fx-font-weight: bold;" maxWidth="Infinity" GridPane.columnIndex="3" />
                <Label text="Thời gian còn lại" style="-fx-background-color: #eee; -fx-padding: 8; -fx-font-weight: bold;" maxWidth="Infinity" GridPane.columnIndex="4" />

                <Label fx:id="lblId" style="-fx-background-color: white; -fx-padding: 8;" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <Label fx:id="lblName" style="-fx-background-color: white; -fx-padding: 8;" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                <Label fx:id="lblBasePrice" style="-fx-background-color: white; -fx-padding: 8;" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="2" />
                <Label fx:id="lblCurrentPrice" style="-fx-background-color: white; -fx-padding: 8;" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="3" />
                <Label fx:id="lblCountdown" style="-fx-background-color: white; -fx-padding: 8;" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="4" />
            </children>
        </GridPane>

        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
            <children>
                <Label text="Nhập giá thầu:" prefWidth="110" style="-fx-font-weight: bold;" />
                <TextField fx:id="txtNormalBid" prefWidth="150" promptText="Nhập số tiền..." />
                <Label fx:id="lblStatus" text="..." textFill="#e74c3c" wrapText="true" maxWidth="300" />
            </children>
        </HBox>
        <Button text="Gửi giá thầu" onAction="#handleNormalBid" prefWidth="150" style="-fx-background-color: #5bc0de; -fx-text-fill: white; -fx-font-weight: bold;">
            <VBox.margin><Insets left="120" /></VBox.margin>
        </Button>

        <Separator />

        <VBox spacing="10" style="-fx-border-color: #ddd; -fx-padding: 15; -fx-background-color: #fafafa; -fx-border-radius: 5;">
            <children>
                <Label text="Đấu giá tự động (Auto-Bidding):" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="110" />
                        <ColumnConstraints prefWidth="150" />
                        <ColumnConstraints prefWidth="180" />
                    </columnConstraints>
                    <children>
                        <Label text="Mức giá tối đa:" GridPane.rowIndex="0" />
                        <TextField fx:id="txtMaxBid" promptText="Ví dụ: 1000000" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                        <Label text="Bước giá nhảy:" GridPane.rowIndex="1" />
                        <TextField fx:id="txtIncrement" promptText="Ví dụ: 10000" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                        <Button text="Kích hoạt tự động" onAction="#handleAutoBid" prefWidth="180" style="-fx-background-color: #5cb85c; -fx-text-fill: white; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="2" />
                    </children>
                </GridPane>
            </children>
        </VBox>

        <HBox alignment="BOTTOM_RIGHT">
            <Button text="Thoát" onAction="#handleExit" prefWidth="100" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" />
        </HBox>
    </children>
</VBox>