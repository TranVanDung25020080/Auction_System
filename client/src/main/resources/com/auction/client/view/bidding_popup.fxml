<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<ScrollPane fitToWidth="true" stylesheets="@../css/bidding-popup-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.biddingpopup.BiddingPopupController">
    <content>
        <VBox spacing="20.0" styleClass="root-container">
            <children>
                <Label alignment="CENTER" maxWidth="Infinity" styleClass="header-title" text="CHI TIẾT PHIÊN ĐẤU GIÁ" />

                <GridPane hgap="1.0" styleClass="info-grid" vgap="1.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" percentWidth="10" />
                        <ColumnConstraints hgrow="SOMETIMES" percentWidth="30" />
                        <ColumnConstraints hgrow="SOMETIMES" percentWidth="20" />
                        <ColumnConstraints hgrow="SOMETIMES" percentWidth="20" />
                        <ColumnConstraints hgrow="SOMETIMES" percentWidth="20" />
                    </columnConstraints>
                    <children>
                        <Label maxWidth="Infinity" styleClass="grid-header" text="Mã ID" />
                        <Label maxWidth="Infinity" styleClass="grid-header" text="Tên sản phẩm" GridPane.columnIndex="1" />
                        <Label maxWidth="Infinity" styleClass="grid-header" text="Giá khởi điểm" GridPane.columnIndex="2" />
                        <Label maxWidth="Infinity" styleClass="grid-header" text="Giá hiện tại" GridPane.columnIndex="3" />
                        <Label maxWidth="Infinity" styleClass="grid-header" text="Thời gian còn lại" GridPane.columnIndex="4" />

                        <Label fx:id="lblId" maxWidth="Infinity" styleClass="grid-cell" GridPane.rowIndex="1" />
                        <Label fx:id="lblName" maxWidth="Infinity" styleClass="grid-cell" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label fx:id="lblBasePrice" maxWidth="Infinity" styleClass="grid-cell" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                        <Label fx:id="lblCurrentPrice" maxWidth="Infinity" styleClass="grid-cell" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                        <Label fx:id="lblCountdown" maxWidth="Infinity" styleClass="grid-cell" GridPane.columnIndex="4" GridPane.rowIndex="1" />
                    </children>
                </GridPane>

                <VBox styleClass="chart-container" VBox.vgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;" text="Lịch sử diễn biến giá" />
                        <LineChart fx:id="priceHistoryChart" animated="false" minHeight="400">
                            <xAxis>
                                <CategoryAxis label="Thời gian" side="BOTTOM" animated="false" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Giá (VNĐ)" side="LEFT" autoRanging="true" forceZeroInRange="false" />
                            </yAxis>
                        </LineChart>
                    </children>
                </VBox>

                <VBox spacing="10" styleClass="control-section">
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <children>
                            <Label style="-fx-font-weight: bold;" text="Nhập giá thầu:" />
                            <TextField fx:id="txtNormalBid" prefWidth="200" />
                            <Button fx:id="normalBidButton" styleClass="btn-bid" text="Gửi giá thầu" />
                        </children>
                    </HBox>
                    <Label fx:id="lblStatus" text="..." textFill="#e74c3c" />
                    <Label fx:id="lblAnnouncement" styleClass="announcement-text" />
                </VBox>

                <Separator />

                <VBox spacing="15" styleClass="auto-bid-pane">
                    <Label style="-fx-font-weight: bold;" text="Cài đặt đấu giá tự động" />
                    <GridPane hgap="10" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="120" />
                            <ColumnConstraints hgrow="ALWAYS" />
                            <ColumnConstraints minWidth="180" />
                        </columnConstraints>
                        <children>
                            <Label text="Mức giá tối đa:" />
                            <TextField fx:id="txtMaxBid" GridPane.columnIndex="1" />
                            <Label text="Bước giá nhảy:" GridPane.rowIndex="1" />
                            <TextField fx:id="txtIncrement" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                            <Button fx:id="autoBidButton" maxWidth="Infinity" styleClass="btn-auto" text="Kích hoạt tự động" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                        </children>
                    </GridPane>
                </VBox>

                <HBox alignment="CENTER_RIGHT">
                    <Button fx:id="exitButton" styleClass="btn-exit" text="Thoát" />
                </HBox>
            </children>
        </VBox>
    </content>
</ScrollPane>