<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" styleClass="wallet-root"
      stylesheets="@../css/seller-wallet-styles.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.sellerwallet.SellerWalletController">

    <Label text="DOANH THU CỦA TÔI" styleClass="wallet-title" />

    <VBox alignment="CENTER" styleClass="balance-card">
        <Label text="Tổng số dư" styleClass="card-label" />
        <Label fx:id="lblBalance" text="0 VNĐ" styleClass="card-value" />
    </VBox>

    <HBox alignment="CENTER" spacing="15.0">
        <Button onAction="#handleWithdraw" styleClass="btn-withdraw" text="Rút tiền" />
        <Button onAction="#handleClose" styleClass="btn-close" text="Đóng" />
    </HBox>
</VBox>