<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.productcard.ProductCardController">
   <children>
      <VBox prefWidth="250.0" spacing="10.0" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 10; -fx-background-radius: 10;" styleClass="product-card">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
         <children>
            <ImageView fx:id="imageProduct" fitHeight="150.0" fitWidth="220.0" pickOnBounds="true" preserveRatio="true" />

            <Label fx:id="ProductName" text="Tên sản phẩm" wrapText="true">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
            </Label>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label text="Giá:" />
                  <Label fx:id="lblPrice" style="-fx-text-fill: red; -fx-font-weight: bold;" text="0 VNĐ" />
                  <Region HBox.hgrow="ALWAYS" /> <Label fx:id="lblTimer" style="-fx-text-fill: #666;" text="00:15:30" />
               </children>
            </HBox>

            <Button fx:id="btnBid" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleBid" prefHeight="40.0" styleClass="bid-button" text="ĐẤU GIÁ NGAY" />
         </children>
      </VBox>
   </children>
</AnchorPane>
