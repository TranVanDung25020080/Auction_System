<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="auctionCard" spacing="10" styleClass="card-auction" prefWidth="260"
      stylesheets="@../css/seller-styles.css"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.auctioncardseller.AuctionCardSellerController">

    <children>
        <HBox alignment="CENTER_LEFT">
            <children>
                <Label text="● LIVE" styleClass="badge-live" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblAuctionId" styleClass="text-id-small" />
            </children>
        </HBox>

        <Label fx:id="lblItemName" styleClass="item-title" />

        <VBox spacing="5" styleClass="price-container">
            <children>
                <Label text="Giá cao nhất hiện tại:" styleClass="label-sub-text" />
                <Label fx:id="lblCurrentPrice" styleClass="price-text-large" />
                <Label fx:id="lblWinnerInfo" styleClass="winner-info-text" />
            </children>
        </VBox>

        <VBox alignment="CENTER" spacing="2" styleClass="timer-container">
            <children>
                <Label text="THỜI GIAN CÒN LẠI" styleClass="label-timer-header" />
                <Label fx:id="lblTimeLeft" styleClass="timer-display" />
            </children>
        </VBox>

        <Separator />

        <Button text="Lịch sử đặt giá" onAction="#handleViewDetails" maxWidth="Infinity" styleClass="btn-primary" />
    </children>
</VBox>