<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainRoot" prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.SellerDashboardController">

    <left>
        <VBox prefWidth="250.0" spacing="20.0" style="-fx-background-color: #2c3e50;" BorderPane.alignment="CENTER">
            <children>
                <Label text="SELLER PRO" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <Button maxWidth="1.7976931348623157E308" onAction="#handleShowInventory" style="-fx-background-color: #34495e; -fx-text-fill: white;" text="📦 Kho Vật Phẩm" />
                <Button maxWidth="1.7976931348623157E308" onAction="#handleShowAuctions" style="-fx-background-color: #34495e; -fx-text-fill: white;" text="⚖️ Đấu Giá Của Tôi" />
                <Button fx:id="btnAddItem" maxWidth="1.7976931348623157E308" onAction="#handleAddItem" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" text="➕ THÊM VẬT PHẨM" />
            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="30.0" />
            </padding>
        </VBox>
    </left>

    <center>
        <VBox spacing="20.0" style="-fx-background-color: #f8f9fa;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <Label text="📦 KHO VẬT PHẨM CỦA BẠN" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>

                <ScrollPane fitToHeight="false" fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS" />
            </children>
        </VBox>
    </center>
</BorderPane>
