<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="250.0" prefWidth="200.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.InventoryCardController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
    <children>
        <ImageView fx:id="imgItem" fitHeight="120.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true" />
        <Label fx:id="lblItemName" text="Tên vật phẩm" textAlignment="CENTER" wrapText="true">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>
        <Label fx:id="lblStatus" text="Trong kho" textFill="#28a745">
            <font>
                <Font name="System Italic" size="12.0" />
            </font>
        </Label>
        <Button fx:id="btnAuction" maxWidth="1.7976931348623157E308" mnemonicParsing="false" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" text="ĐƯA LÊN SÀN" />
    </children>
</VBox>