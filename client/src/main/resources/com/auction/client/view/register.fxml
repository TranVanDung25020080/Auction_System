<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0" prefWidth="900.0" styleClass="root" stylesheets="@../css/auth-styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.register.RegisterController">
    <children>
        <VBox alignment="CENTER" layoutX="275.0" layoutY="70.0" spacing="20.0" styleClass="form-card" AnchorPane.bottomAnchor="70.0" AnchorPane.leftAnchor="275.0" AnchorPane.rightAnchor="275.0" AnchorPane.topAnchor="70.0">
            <children>
                <Label styleClass="form-title" text="TẠO TÀI KHOẢN MỚI" />

                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="input-label" text="Tên hiển thị" />
                        <TextField fx:id="txtDisplayName" promptText="Nhập tên người dùng của bạn" styleClass="input-field" />
                    </children>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="input-label" text="Tên đăng nhập" />
                        <TextField fx:id="txtUsername" promptText="Nhập tên đăng nhập" styleClass="input-field" />
                    </children>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="input-label" text="Mật khẩu" />
                        <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu" styleClass="input-field" />
                    </children>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Label styleClass="input-label" text="Bạn tham gia với tư cách?" />
                        <HBox alignment="CENTER" spacing="15.0">
                            <children>
                                <ToggleButton fx:id="btnBidderRole" maxWidth="Infinity" mnemonicParsing="false" prefHeight="40.0" selected="true" styleClass="role-button" text="NGƯỜI ĐẤU GIÁ" HBox.hgrow="ALWAYS">
                                    <toggleGroup>
                                        <ToggleGroup fx:id="roleGroup" />
                                    </toggleGroup>
                                </ToggleButton>
                                <ToggleButton fx:id="btnOwnerRole" maxWidth="Infinity" mnemonicParsing="false" prefHeight="40.0" styleClass="role-button" text="CHỦ TÀI SẢN" toggleGroup="$roleGroup" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Button fx:id="registerButton" mnemonicParsing="false" prefHeight="50.0" prefWidth="300.0" styleClass="login-button" text="ĐĂNG KÝ NGAY" />

                <Button fx:id="switchToLoginButton" mnemonicParsing="false" styleClass="link-button" text="Đã có tài khoản? Quay lại Đăng nhập" />
            </children>
            <padding>
                <Insets bottom="40.0" left="50.0" right="50.0" top="40.0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>
