<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="400.0" spacing="15.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AddItemController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="Thêm Vật Phẩm Mới" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </Label>

        <Label text="Tên vật phẩm:" />
        <TextField fx:id="txtItemName" promptText="VD: Đồng hồ Rolex" style="-fx-pref-height: 35;" />

        <Label text="Giá khởi điểm (VNĐ):" />
        <TextField fx:id="txtPrice" promptText="VD: 15000000" style="-fx-pref-height: 35;" />

        <Label text="Đường dẫn ảnh:" />
        <TextField fx:id="txtImageUrl" promptText="/com/auction/client/images/..." style="-fx-pref-height: 35;" />

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <VBox.margin>
                <Insets top="20.0" />
            </VBox.margin>
            <children>
                <Button fx:id="btnCancel" onAction="#handleCancel" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-pref-height: 35; -fx-pref-width: 80;" text="Hủy" />
                <Button fx:id="btnSave" onAction="#handleSave" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-pref-height: 35; -fx-pref-width: 100; -fx-font-weight: bold;" text="Lưu Lại" />
            </children>
        </HBox>
    </children>
</VBox>