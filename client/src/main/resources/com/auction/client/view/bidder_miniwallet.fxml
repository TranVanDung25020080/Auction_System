<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="250.0" prefWidth="450.0" style="-fx-background-color: #f4f6f9; -fx-border-color: #bdc3c7; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.bidderminiwallet.BidderMiniWalletController">
    <children>
        <Label fx:id="titleLabel" alignment="CENTER" layoutX="25.0" layoutY="35.0" prefWidth="400.0" text="Select your max bid that you want during this auction" textAlignment="CENTER" textFill="#2c3e50" wrapText="true">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>

        <TextField fx:id="maxBidField" layoutX="100.0" layoutY="95.0" prefHeight="35.0" prefWidth="250.0" promptText="Enter amount (VND)" style="-fx-padding: 8; -fx-background-radius: 4; -fx-border-color: #dcdde1; -fx-border-radius: 4;">
            <font>
                <Font size="13.0" />
            </font>
        </TextField>

        <Button fx:id="okButton" layoutX="115.0" layoutY="165.0" mnemonicParsing="false" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;" text="OK">
            <font>
                <Font size="13.0" />
            </font>
        </Button>

        <Button fx:id="cancelButton" layoutX="235.0" layoutY="165.0" mnemonicParsing="false" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;" text="Cancel">
            <font>
                <Font size="13.0" />
            </font>
        </Button>
    </children>
</AnchorPane>
