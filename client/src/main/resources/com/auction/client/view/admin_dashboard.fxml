<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="750.0" prefWidth="1200.0" stylesheets="@../css/admin-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AdminDashboardController">
    <left>
        <VBox spacing="15" styleClass="sidebar" prefWidth="250">
            <children>
                <Label text="ADMIN PANEL" styleClass="sidebar-title"/>
                <Separator opacity="0.3"/>
                <Button fx:id="btnUsers" text="Quản lý Người dùng" styleClass="menu-btn" maxWidth="Infinity" />
                <Button fx:id="btnAuctions" text="Quản lý Đấu giá" styleClass="menu-btn" maxWidth="Infinity" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="btnLogout" text="Đăng xuất" styleClass="logout-btn" maxWidth="Infinity" />
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" styleClass="main-scroll">
            <content>
                <VBox spacing="20" styleClass="main-container">
                    <children>
                        <Label fx:id="lblHeader" text="Hệ thống quản lý" styleClass="header-text" />

                        <StackPane>
                            <children>
                                <VBox fx:id="viewUsers" spacing="15">
                                    <TableView fx:id="tableUsers" minHeight="600">
                                        <columns>
                                            <TableColumn fx:id="colUserId" text="ID" prefWidth="60" />
                                            <TableColumn fx:id="colOwnerName" text="Họ tên" prefWidth="200" />
                                            <TableColumn fx:id="colUserName" text="Username" prefWidth="150" />
                                            <TableColumn fx:id="colUserRole" text="Vai trò" prefWidth="120" />
                                            <TableColumn fx:id="colBalance" text="Số dư (VNĐ)" prefWidth="150" />
                                        </columns>
                                    </TableView>
                                </VBox>

                                <VBox fx:id="viewAuctions" spacing="20" visible="false">
                                    <Label text="Danh sách phiên đấu giá" styleClass="sub-header"/>
                                    <TableView fx:id="tableAuctions" minHeight="400">
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                        </columnResizePolicy>
                                        <columns>
                                            <TableColumn fx:id="colAuctionId" text="Mã ID" prefWidth="50" />
                                            <TableColumn fx:id="colItemName" text="Tên sản phẩm" prefWidth="300" />
                                            <TableColumn fx:id="colCurrentPrice" text="Giá hiện tại" prefWidth="120" />
                                            <TableColumn fx:id="colAuctionStatus" text="Trạng thái" prefWidth="100" />
                                        </columns>
                                    </TableView>

                                    <Label text="Chi tiết lịch sử đặt giá (Bid History)" styleClass="sub-header"/>
                                    <TableView fx:id="tableTransactions" minHeight="300">
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                        </columnResizePolicy>
                                        <columns>
                                            <TableColumn fx:id="colTransId" text="Mã GD" prefWidth="80" />
                                            <TableColumn fx:id="colTransBidder" text="Mã Người thầu" prefWidth="150" />
                                            <TableColumn fx:id="colTransAmount" text="Số tiền thầu" prefWidth="150" />
                                            <TableColumn fx:id="colTransTime" text="Thời gian" prefWidth="200" />
                                        </columns>
                                    </TableView>
                                </VBox>
                            </children>
                        </StackPane>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>