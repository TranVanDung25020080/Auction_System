<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="500.0" spacing="20.0" styleClass="form-container"
      stylesheets="@../css/seller-styles.css"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.additem.AddItemController">

    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>

    <children>
        <Label styleClass="header-title" text="THÔNG TIN SẢN PHẨM MỚI" />

        <GridPane hgap="15.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" prefWidth="120.0" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
            </columnConstraints>

            <children>
                <Label text="Loại mặt hàng:" GridPane.rowIndex="0" />
                <ComboBox fx:id="cbItemType" maxWidth="Infinity" onAction="#handleTypeChange"
                          promptText="Chọn loại sản phẩm..." GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Tên sản phẩm:" GridPane.rowIndex="1" />
                <TextField fx:id="txtName" styleClass="form-input" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Giá khởi điểm:" GridPane.rowIndex="2" />
                <TextField fx:id="txtPrice" promptText="VNĐ" styleClass="form-input" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Mô tả:" GridPane.rowIndex="3" />
                <TextArea fx:id="txtDescription" prefHeight="80.0" styleClass="form-input"
                          wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            </children>
        </GridPane>

        <VBox fx:id="vboxDynamicFields" spacing="15.0" styleClass="dynamic-section" />

        <Separator />

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <children>
                <Button onAction="#handleCancel" prefWidth="100.0" styleClass="btn-secondary" text="Hủy bỏ" />
                <Button onAction="#handleSave" prefWidth="150.0" styleClass="btn-primary" text="Lưu vào kho hàng" />
            </children>
        </HBox>
    </children>
</VBox>